{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "🚀 Start Django Backend",
      "type": "shell",
      "command": "venv\\Scripts\\activate && python manage.py runserver",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "name": "Django Backend"
      },
      "problemMatcher": []
    },
    {
      "label": "⚙️ Start Celery Worker",
      "type": "shell",
      "command": "venv\\Scripts\\activate && celery -A hita_project worker --loglevel=info --pool=solo",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "name": "Celery Worker"
      },
      "problemMatcher": []
    },
    {
      "label": "🎨 Start Next.js Frontend",
      "type": "shell",
      "command": "npm run dev",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "name": "Next.js Frontend"
      },
      "problemMatcher": []
    },
    {
      "label": "🗃️ Run Django Migrations",
      "type": "shell",
      "command": "venv\\Scripts\\activate && python manage.py migrate",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "name": "Migrations"
      },
      "problemMatcher": []
    },
    {
      "label": "📦 Install Backend Dependencies",
      "type": "shell",
      "command": "venv\\Scripts\\activate && pip install -r requirements.txt",
      "options": {
        "cwd": "${workspaceFolder}\\backend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "📦 Install Frontend Dependencies",
      "type": "shell",
      "command": "npm install",
      "options": {
        "cwd": "${workspaceFolder}\\frontend"
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "🏗️ Start Full Hita App",
      "dependsOn": [
        "🚀 Start Django Backend",
        "⚙️ Start Celery Worker",
        "🎨 Start Next.js Frontend"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
